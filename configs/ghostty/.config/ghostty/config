# Ghostty — https://ghostty.org/docs/config

theme = Tokyo Night

font-size = 11
font-family = JetBrainsMono NF

clipboard-read = allow
clipboard-write = allow

mouse-hide-while-typing = true
clipboard-trim-trailing-spaces = true
clipboard-paste-protection = false

# Linux-only: hide GTK titlebar (no-op on macOS)
gtk-titlebar = false

# macOS-only tweaks
macos-option-as-alt = true

# Linux/Wayland: fix slowness on Hyprland (no-op on macOS)
# https://github.com/ghostty-org/ghostty/discussions/3224
# async-backend = epoll  # Uncomment on Linux; macOS uses kqueue by default
